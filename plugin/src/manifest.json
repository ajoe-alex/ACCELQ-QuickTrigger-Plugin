{
  "manifest_version": 3,
  "name": "ACCELQ QuickTrigger",
  "version": "1.0.0",
  "description": "Trigger and monitor ACCELQ job runs from a dashboard, without hitting browser CORS restrictions.",
  "action": {
    "default_title": "Open ACCELQ QuickTrigger",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "host_permissions": ["https://*.accelq.io/*"]
}
